<Page
    x:Class="OseiVPN.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OseiVPN.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#0F172A" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="Osei VPN - Windows (Starter)" Foreground="White" HorizontalAlignment="Center" FontSize="20"/>
            <TextBlock Text="Status:" Foreground="#94A3B8" />
            <TextBlock Text="{Binding Status}" Foreground="#06B6D4" FontSize="16" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Button Content="Connect" Width="120" Click="OnConnectClick" />
                <Button Content="Disconnect" Width="120" Click="OnDisconnectClick" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
